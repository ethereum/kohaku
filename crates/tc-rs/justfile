fork_url := env_var("RPC_URL_SEPOLIA")

integration: integration-sync integration-sync-relayer

integration-sync:
    #!/usr/bin/env bash
    set -euo pipefail

    # Start anvil in background
    anvil --fork-url {{fork_url}} --port 8545 &
    ANVIL_PID=$!
    trap "kill $ANVIL_PID" EXIT

    # Wait for anvil to be ready
    sleep 2

    RUST_LOG=info cargo test --no-default-features -- test_sync_indexer --ignored --nocapture

integration-sync-relayer:
    RUST_LOG=info cargo test -- test_sync_broadcaster --ignored --nocapture
