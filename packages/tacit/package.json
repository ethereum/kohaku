  },
  "dependencies": {
    "@kohaku-eth/plugins": "workspace:*",
    "@kohaku-eth/provider": "workspace:*",
    "poseidon-lite": "^0.3.0",
    "ox": "^0.6.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
