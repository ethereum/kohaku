{
  "name": "@kohaku-eth/tacit",
  "version": "0.0.1-alpha.0",
  "description": "Tacit cross-chain privacy plugin — shielded ETH/ERC-20 bridge via Bitcoin-verified ZK mixer",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
