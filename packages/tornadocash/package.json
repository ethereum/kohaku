{
  "name": "@kohaku-eth/tornadocash",
  "version": "0.0.1-alpha.4",
  "description": "Simplified Tornadocash TS utils",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum/kohaku.git",
    "directory": "packages/tornadocash"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./storage/layers/file": {
      "types": "./dist/storage/layers/file.d.ts",
      "import": "./dist/storage/layers/file.js"
    },
    "./storage/layers/empty": {
      "types": "./dist/storage/layers/empty.d.ts",
      "import": "./dist/storage/layers/empty.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs",
      "default": "./dist/webpack.js"
    },
    "./package.json": "./package.json"
  },
  "browser": {
    "module": false,
    "crypto": false,
    "fs": false,
    "path": false
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "echo Building @kohaku-eth/tornadocash && tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run tests/e2e",
    "prepublishOnly": "pnpm -w -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@corpus-core/colibri-stateless": ">=1.1.0 <2",
    "ethers": "^6.13.1",
    "snarkjs": "^0.7.5"
  },
  "peerDependenciesMeta": {
    "@corpus-core/colibri-stateless": {
      "optional": true
    },
    "snarkjs": {
      "optional": true
    }
  },
  "dependencies": {
    "@kohaku-eth/plugins": "workspace:*",
    "@kohaku-eth/provider": "workspace:*",
    "tc-js": "https://github.com/Robert-MacWha/privacy-protocols/releases/download/v0.1.3/tc-js-0.1.0.tgz"
  }
}