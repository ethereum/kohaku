{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": false,
    "declarationMap": false,
    "target": "es2022",
    "lib": [
      "es2022",
      "dom"
    ],
    "module": "Node20",
    "moduleResolution": "Node16",
    "strict": true,
    "declaration": true,
    "isolatedDeclarations": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "types",
    "**/*.spec.ts"
  ]
}
