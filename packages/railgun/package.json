{
  "name": "@kohaku-eth/railgun",
  "version": "0.0.1-alpha.8",
  "description": "Simplified Railgun TS utils",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum/kohaku.git",
    "directory": "packages/railgun"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./storage/layers/file": {
      "types": "./dist/storage/layers/file.d.ts",
      "import": "./dist/storage/layers/file.js"
    },
    "./storage/layers/empty": {
      "types": "./dist/storage/layers/empty.d.ts",
      "import": "./dist/storage/layers/empty.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs",
      "default": "./dist/webpack.js"
    },
    "./package.json": "./package.json"
  },
  "browser": {
    "module": false,
    "crypto": false,
    "fs": false,
    "path": false
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm run build:wasm && pnpm run build:js",
    "build:wasm": "wasm-pack build --release --target nodejs ../../crates/railgun-rs --out-dir ../../packages/railgun/src/pkg",
    "build:js": "tsc && mkdir -p dist/pkg && cp -r src/pkg dist/pkg && rm -f dist/pkg/.gitignore",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run tests/e2e",
    "prepublishOnly": "pnpm -w -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@corpus-core/colibri-stateless": ">=1.1.0 <2",
    "ethers": "^6.13.1"
  },
  "peerDependenciesMeta": {
    "@corpus-core/colibri-stateless": {
      "optional": true
    }
  },
  "dependencies": {
    "@kohaku-eth/plugins": "workspace:*",
    "@kohaku-eth/provider": "workspace:*",
    "@waku/sdk": "^0.0.36",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/snarkjs": "^0.7.6",
    "tsx": "^4.17.0",
    "typescript": "^5.9.2",
    "viem": "^2.0.0",
    "vitest": "^4.1.1"
  }
}