{
  "name": "@kohaku-eth/railgun",
  "version": "0.0.1-alpha.9",
  "description": "Simplified Railgun TS utils",
  "type": "module",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum/kohaku.git",
    "directory": "packages/railgun"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run build:wasm && pnpm run build:js",
    "build:wasm": "wasm-pack build --release --target web ../../crates/railgun-rs --out-dir ../../packages/railgun/src/pkg",
    "build:js": "tsc && mkdir -p dist/pkg && cp -r src/pkg dist/pkg && rm -f dist/pkg/.gitignore",
    "test:browser": "vite serve e2e",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@kohaku-eth/plugins": "workspace:*",
    "@kohaku-eth/provider": "workspace:*",
    "@waku/sdk": "^0.0.36",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/snarkjs": "^0.7.6",
    "typescript": "^5.9.2",
    "viem": "^2.0.0",
    "vite": "^8.0.2",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.1"
  }
}