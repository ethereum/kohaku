fork_url := env_var("RPC_URL_MAINNET")
fork_block := "24379760"

wasm:
    wasm-pack build --release --target web ../../crates/railgun-rs --out-dir ../../packages/railgun/src/pkg

integration: wasm integration-sync-utxo integration-transact

integration-sync-utxo: wasm
    INTEGRATION=1 pnpm vitest run -t sync-utxo

integration-sync-utxo-browser: wasm
    INTEGRATION=1 pnpm vitest run --config vitest.config.browser.ts -t sync-utxo-browser

integration-transact: wasm
    just with-anvil "INTEGRATION=1 pnpm vitest run -t transact-utxo"

integration-transact-poi: wasm
    pnpm vitest run -t transact-poi

[private]
with-anvil *args:
    #!/usr/bin/env bash
    set -euo pipefail
    anvil --fork-url {{fork_url}} --fork-block-number {{fork_block}} --port 8545 --load-state ../../crates/railgun-rs/tests/fixtures/state.json &
    ANVIL_PID=$!
    trap "kill $ANVIL_PID 2>/dev/null" EXIT
    sleep 2
    {{args}}